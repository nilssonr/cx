{erl_opts, [debug_info]}.

{plugins, [erlfmt]}.

{erlfmt, [
    write,
    {files, [
        "apps/*/{src,include,test}/*.{erl,hrl,app.src}",
        "rebar.config"
    ]}
]}.

{deps, [
    {jose, "1.11.10"},
    {cowboy, "2.13.0"},
    %% types-only companion for eqWAlizer (eqwalizer:dynamic() etc.);
    %% no runtime code of consequence
    {eqwalizer_support,
        {git_subdir, "https://github.com/whatsapp/eqwalizer.git", {tag, "v0.25.3"},
            "eqwalizer_support"}}
]}.

%% jose 1.11.10 sets warnings_as_errors and OTP 29 deprecates `case catch`;
%% silence the deprecation so the dep builds. Drop when jose releases a fix.
{overrides, [
    {add, jose, [{erl_opts, [nowarn_deprecated_catch]}]}
]}.

{relx, [
    {release, {cx, "0.1.0"}, [
        cx_core,
        cx_auth,
        cx_router,
        cx_api_rest,
        {mnesia, load},
        sasl
    ]},

    {mode, dev},

    {sys_config, "./config/sys.config"},
    {vm_args, "./config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod}
        ]}
    ]},
    {test, [
        {deps, [
            {proper, "1.4.0"}
        ]}
    ]},
    %% CI compiles our apps with warnings-as-errors (deps keep their own
    %% opts; the jose override above handles its noise)
    {ci, [
        {erl_opts, [warnings_as_errors]}
    ]}
]}.
