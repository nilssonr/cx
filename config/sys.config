[
    {cx_core, [
        {mnesia_dir, "data/mnesia"}
    ]},

    {cx_auth, [
        {issuer, <<"http://localhost:8081">>},
        {audiences, [<<"cx-api">>]},
        {key_source, {jwks, <<"http://localhost:8081/oauth/v2/keys">>}},
        %% Dev only: Zitadel in docker/docker-compose.yml serves plain
        %% HTTP on localhost. Production deployments MUST leave this at
        %% its default (false): JWKS is then fetched with verify_peer +
        %% the OS trust store, and plain-http URLs refuse to boot.
        {allow_insecure_jwks, true},
        {jwks_refresh_ms, 300000},
        {tenant_claim, <<"urn:zitadel:iam:org:id">>},
        %% Bootstrap: token subjects granted full permissions WITHOUT a
        %% cx_user row. A fresh deployment has zero tenants/users, and
        %% this list is the only way to create the first tenant — put
        %% your IdP admin subject(s) here, then shrink the list back
        %% once real admin users exist (each entry is a standing
        %% platform superuser).
        {platform_admin_subjects, [<<"bootstrap-admin">>]},
        %% Local admin seeded at boot on a fresh deployment. CHANGE THE
        %% PASSWORD on any real deployment; this only bootstraps a dev box.
        {bootstrap_admin, #{
            subject => <<"bootstrap-admin">>,
            email => <<"admin@cx.local">>,
            password => <<"pass">>
        }},
        {first_party_clients, [
            #{
                client_id => <<"cx-agent-spa">>,
                type => public,
                grant_types => [<<"authorization_code">>, <<"refresh_token">>],
                redirect_uris => [<<"http://localhost:3000/callback">>],
                scopes => [<<"openid">>, <<"profile">>, <<"email">>]
            },
            #{
                client_id => <<"cx-agent-mobile">>,
                type => public,
                grant_types => [<<"authorization_code">>, <<"refresh_token">>],
                redirect_uris => [<<"cx.agent://callback">>],
                scopes => [<<"openid">>, <<"profile">>, <<"email">>]
            }
        ]}
    ]},

    {cx_presence, [
        {away_threshold_ms, 300000}
    ]},

    {cx_api_rest, [
        {port, 8080},
        {ip, {0, 0, 0, 0}},
        {acceptors, 10}
    ]},

    {kernel, [
        {logger_level, info}
    ]}
].
